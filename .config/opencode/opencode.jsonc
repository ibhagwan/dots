{
  //
  // https://opencode.ai/docs/
  //
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/kimi-k2.6",
  "theme": "opencode",
  "default_agent": "plan",
  "autoupdate": true,
  "instructions": ["{env:HOME}/.config/opencode/INSTRUCTIONS.md"],
  "tui": {
    "cursor_blinking": true,
    "scroll_speed": 8,
    "scroll_acceleration": {
      "enabled": true,
    },
  },
  "keybinds": {
    "leader": "ctrl+x",
    "app_exit": "ctrl+c,<leader>q",
    "input_submit": "alt+return,ctrl+return",
    "input_newline": "return,shift+return,ctrl+j",
    "messages_page_up": "pageup,ctrl+alt+b",
    "messages_page_down": "pagedown,ctrl+alt+f",
    "messages_half_page_up": "ctrl+alt+u,ctrl+b",
    "messages_half_page_down": "ctrl+d,ctrl+alt+d,ctrl+f",
    "messages_first": "alt+g,ctrl+g,home",
    "messages_last": "ctrl+alt+g,end",
  },
  "agent": {
    "build": {
      "color": "secondary",
    },
    "plan": {
      "color": "accent",
    },
  },
  "provider": {
    "nvidia": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Nvidia",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1",
        "apiKey": "{env:NVIDIA_API_KEY}",
      },
      "models": {
        "qwen/qwen3.5-397b-a17b": { "name": "Qwen3.5 397B A17B Free" },
        "minimaxai/minimax-m2.7": { "name": "MiniMax M2.7 Free" },
      },
    },
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}",
        "baseURL": "https://openrouter.ai/api/v1",
      },
    },
  },
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  // hermes-agent doesn't use a formatter
  // "formatter": { "ruff": { "disabled": true } },
}
